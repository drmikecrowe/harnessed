.claude/*
.npm
pip
.local

extra-tools.txt

!.claude/.gitkeep

.dockerignore

# Generated stack profiles — output of `harnessed build`, regenerated on every build.
# stacks/<name>/stack.yaml is the authored source of truth; profiles/ is the mount artifact.
/profiles/

# DX symlinks: catalog/<kind>.local → ~/.config/harnessed/catalog/<kind> (created by `harnessed build`).
catalog/*.local

# Throwaway fixture profiles emitted by `harnessed build <fixture-stack> --root tools/test-fixtures`.
tools/test-fixtures/profiles/

# Stray SSH debug log (not part of the project)
ssh-verbose.log

# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
.venv/
