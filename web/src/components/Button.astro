---
/**
 * DESIGN.md button system. All variants are pill (radius-full).
 * No-hover policy honoured: default + pressed/active states only.
 */
interface Props {
  variant?: "primary" | "secondary" | "tertiary" | "link";
  href?: string;
  class?: string;
}

const {
  variant = "primary",
  href,
  class: className = "",
} = Astro.props;

const Tag = href ? "a" : "button";
---

<Tag class={`btn btn--${variant} ${className}`.trim()} href={href}>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    font-size: var(--text-button-md);
    font-weight: 600;
    line-height: 1.4;
    padding: 11px 24px;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
    white-space: nowrap;
  }
  .btn--primary {
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
  }
  .btn--primary:active {
    background: var(--color-charcoal);
  }
  .btn--secondary {
    background: transparent;
    color: var(--color-ink);
    border-color: var(--color-ink);
  }
  .btn--tertiary {
    background: var(--color-canvas);
    color: var(--color-ink);
    border-color: var(--color-hairline);
  }
  .btn--link {
    background: transparent;
    color: var(--color-ink);
    padding: var(--space-xs) 0;
    border-radius: 0;
    border: none;
  }
  .btn--link:active {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
