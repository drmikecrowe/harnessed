#!/usr/bin/env bash
# harnessed — launch isolated, composable harness stacks.
#
# Host-native: podman/docker is the only host dependency. The host builds images
# (`podman build`) and runs containers directly; there is NO daemon-in-container,
# NO rootless API socket, and NO Docker-out-of-Docker (design §15).
#
# Surface:
#   harnessed transparent [path]   launch the host-mirror stack (today's `container`)
#   harnessed [path]               default stack = transparent
#   harnessed <stack> [path] [--fresh]   launch an isolated stack: assembled profile + pod (harness + hatago)
#   harnessed build [<stack>]      assemble a stack (emit-only) + build hatago, or rebuild base/claude/hatago images
#   harnessed list                 list authored stacks + running instances
#   harnessed stop <stack>         stop every instance of a stack
#   harnessed rm <stack>           remove every instance of a stack
#   harnessed new <stack> [--harness <h>] [--recipes a,b,c]   scaffold a stack manifest
#   harnessed --list               (legacy) list harnessed instances
#   harnessed --stop   [path]      (legacy) stop the instance for a project
#   harnessed --remove [path]      (legacy) remove the instance for a project
#   harnessed --clean              (legacy) remove all stopped harnessed instances
#   harnessed --no-firewall ...    skip the egress firewall for this run

set -euo pipefail

# Resolve this script's real directory (follow symlinks so a PATH symlink works).
SCRIPT_PATH="$0"
while [ -L "$SCRIPT_PATH" ]; do SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"; done
HARNESSED_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
export HARNESSED_DIR

# shellcheck source=lib/harnessed-common.sh
. "$HARNESSED_DIR/lib/harnessed-common.sh"

usage() {
    cat <<'EOF'
harnessed — launch isolated, composable harness stacks

Usage:
  harnessed [stack] [path]        Launch a stack (default stack: transparent)
  harnessed transparent [path]    Host-mirror stack: live host config + project
  harnessed <stack> [path] [--fresh]
                                  Isolated stack: assembled profile + pod (harness + hatago)
  harnessed build <stack>         Assemble a stack into a committed profile + build the hatago image
  harnessed build | --build       (Re)build the base/claude/hatago images
  harnessed test <stack>          Capability test: launch the stack --fresh headless + assert it
                                  exposes the manifest's declared MCP servers/skills (markdown report)
  harnessed svc up <service>      Start a shared service sidecar on harnessed-net (own image + volume)
  harnessed svc down <service>    Stop a service (volume kept); add --purge to remove the volume
  harnessed svc list              List running harnessed-managed services
  harnessed list                  List authored stacks + running instances
  harnessed stop <stack>          Stop every instance of a stack (all projects)
  harnessed rm <stack>            Remove every instance of a stack (all projects)
  harnessed new <stack> [--harness <claude|omp>] [--recipes a,b,c]   Scaffold a stack manifest (refuses overwrite; harness validated)
  harnessed --list                (legacy) List harnessed instances
  harnessed --stop   [stack] [path]   (legacy) Stop the instance/pod for a project
  harnessed --remove [stack] [path]   (legacy) Remove the instance/pod for a project
  harnessed --clean               (legacy) Remove all stopped harnessed instances
  harnessed --fresh ...           Tear down any existing pod/instance first (isolated)
  harnessed --no-firewall ...     Skip the egress firewall for this run
  harnessed -h | --help           Show this help

Podman (or docker) is the only host dependency.
EOF
}

detect_runtime

# --- Parse args ------------------------------------------------------------
BUILD=false; LIST=false; STOP=false; REMOVE=false; CLEAN=false; FRESH=false
CLAUDE=false; ZAI=false; STACK_SELECTED=false
STACK="transparent"; PROJECT_PATH=""; BUILD_STACK=""; TEST=false; TEST_ARGS=(); TEST_STACK=""; ROOT_OVERRIDE=""
SVC_ACTION=""; SVC_TARGET=""; SVC_PURGE=false
SUB_LIST=false; SUB_STOP=false; SUB_REMOVE=false
SUB_STOP_STACK=""; SUB_RM_STACK=""
SUB_NEW=false; SUB_NEW_STACK=""; SUB_NEW_HARNESS="claude"; SUB_NEW_RECIPES=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)      usage; exit 0 ;;
        -b|--build)     BUILD=true; shift ;;
        build)
            BUILD=true; shift
            # `harnessed build <stack>` assembles a stack; bare `harnessed build` rebuilds images.
            if [[ $# -gt 0 && "$1" != -* ]]; then BUILD_STACK="$1"; shift; fi
            ;;
        test)
            # `harnessed test <stack> [flags]` → per-stack capability test (design §18). Consume the
            # rest of argv verbatim (stack + any --json/--keep) as the python cli's test invocation.
            TEST=true; shift
            TEST_ARGS=("$@")
            if [[ ${#TEST_ARGS[@]} -gt 0 && "${TEST_ARGS[0]}" != -* ]]; then TEST_STACK="${TEST_ARGS[0]}"; fi
            break
            ;;
        svc)
            # `harnessed svc up|down|list <service>` → shared service lifecycle (plan 04-01 / SVC-01).
            # Parsed BEFORE the stack-name fallthrough so a service named like a stack does not collide.
            shift
            SVC_ACTION="${1:-}"
            [ -n "$SVC_ACTION" ] || { print_error "svc requires an action (up|down|list)"; usage; exit 1; }
            shift
            case "$SVC_ACTION" in
                up)
                    [ $# -gt 0 ] || { print_error "svc up requires a service name"; usage; exit 1; }
                    SVC_TARGET="$1"; shift
                    ;;
                down)
                    [ $# -gt 0 ] || { print_error "svc down requires a service name"; usage; exit 1; }
                    SVC_TARGET="$1"; shift
                    [ "${1:-}" = "--purge" ] && { SVC_PURGE=true; shift; }
                    ;;
                list)
                    SVC_TARGET=""
                    ;;
                *)
                    print_error "unknown svc action: $SVC_ACTION (use up|down|list)"; usage; exit 1
                    ;;
            esac
            ;;
        list)
            # `harnessed list` → §13 subcommand: authored stacks + running instances (CLI-01).
            # Parsed before the stack-name fallthrough so a stack named `list` cannot collide (P-04-07).
            SUB_LIST=true; shift
            ;;
        stop)
            # `harnessed stop <stack>` → stop every instance of a stack by name (CLI-01).
            shift
            [ $# -gt 0 ] || { print_error "stop requires a stack name"; usage; exit 1; }
            SUB_STOP=true; SUB_STOP_STACK="$1"; shift
            ;;
        rm)
            # `harnessed rm <stack>` → remove every instance of a stack by name (CLI-01).
            shift
            [ $# -gt 0 ] || { print_error "rm requires a stack name"; usage; exit 1; }
            SUB_REMOVE=true; SUB_RM_STACK="$1"; shift
            ;;
        new)
            # `harnessed new <stack> [--harness <claude|omp>] [--recipes a,b,c]` → scaffold a
            # stack manifest (CLI-02). Parsed before the stack-name fallthrough (P-04-07).
            shift
            [ $# -gt 0 ] || { print_error "new requires a stack name"; usage; exit 1; }
            SUB_NEW_STACK="$1"; shift
            while [ $# -gt 0 ]; do
                case "$1" in
                    --harness)
                        [ $# -ge 2 ] || { print_error "--harness requires a value (claude|omp)"; exit 1; }
                        SUB_NEW_HARNESS="$2"; shift 2 ;;
                    --recipes)
                        [ $# -ge 2 ] || { print_error "--recipes requires a comma-joined value"; exit 1; }
                        SUB_NEW_RECIPES="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) print_error "new: unknown option $1"; usage; exit 1 ;;
                    *) break ;;
                esac
            done
            SUB_NEW=true
            ;;
        -l|--list)      LIST=true; shift ;;
        -s|--stop)      STOP=true; shift ;;
        -r|--remove)    REMOVE=true; shift ;;
        --clean)        CLEAN=true; shift ;;
        --no-firewall)  NO_FIREWALL=true; export NO_FIREWALL; shift ;;
        --root)
            # `--root <dir>` → HARNESSED_ROOT: an alternate stacks/ + recipes/ root for
            # `harnessed build` (PORT-01) and the fixture build path (BLOCKER-2(b)).
            shift
            [ $# -gt 0 ] || { print_error "--root requires a directory argument"; usage; exit 1; }
            ROOT_OVERRIDE="$1"; shift
            ;;
        --claude)       CLAUDE=true; shift ;;
        --zai)          ZAI=true; shift ;;
        --fresh)        FRESH=true; shift ;;
        transparent)    STACK="transparent"; STACK_SELECTED=true; shift ;;
        -*)             print_error "Unknown option: $1"; usage; exit 1 ;;
        *)
            # First bareword: a stack name (stacks/<name>/stack.yaml) OR a non-existent stack-like
            # token selects the stack (the dispatch validates + errors clearly); an existing
            # directory is the project path for the default transparent stack. Second bareword is
            # always the project path.
            if [ "$STACK_SELECTED" = false ] && [ -z "$PROJECT_PATH" ]; then
                if [ -f "$HARNESSED_DIR/stacks/$1/stack.yaml" ]; then
                    STACK="$1"; STACK_SELECTED=true
                elif [ -d "$1" ]; then
                    PROJECT_PATH="$1"
                else
                    STACK="$1"; STACK_SELECTED=true
                fi
            elif [ -z "$PROJECT_PATH" ]; then
                PROJECT_PATH="$1"
            else
                print_error "Unexpected argument: $1"; usage; exit 1
            fi
            shift ;;
    esac
done

# --- Resolve --root to an absolute HARNESSED_ROOT (default: the repo) --------------
# `harnessed build <stack> --root <dir>` exercises the full wired build path against an alternate
# stacks/ + recipes/ root (fixtures or a multi-project layout) without polluting the real stacks/
# + recipes/. build_stack reads ROOT=${HARNESSED_ROOT:-$HARNESSED_DIR}.
if [ -n "$ROOT_OVERRIDE" ]; then
    if [ ! -d "$ROOT_OVERRIDE" ]; then
        print_error "--root: not a directory: $ROOT_OVERRIDE"; exit 1
    fi
    HARNESSED_ROOT="$(cd "$ROOT_OVERRIDE" && pwd)"
    export HARNESSED_ROOT
fi

# --- Service lifecycle (plan 04-01 / SVC-01, SVC-03) ------------------------
# `harnessed svc up|down|list <service>` manages shared service sidecars on harnessed-net
# (own image/container/volume, labelled harnessed-service=<name>). Dispatch exits — svc is a
# top-level command, not a launch path.
if [ -n "$SVC_ACTION" ]; then
    # shellcheck source=lib/harnessed-services.sh
    . "$HARNESSED_DIR/lib/harnessed-services.sh"
    case "$SVC_ACTION" in
        up)   svc_up "$SVC_TARGET" ;;
        down)
            if [ "$SVC_PURGE" = true ]; then
                svc_down "$SVC_TARGET" --purge
            else
                svc_down "$SVC_TARGET"
            fi
            ;;
        list) svc_list ;;
    esac
    exit 0
fi

# --- §13 stack/instance subcommands (plan 04-02 / CLI-01): list | stop <stack> | rm <stack> ---
# First-class subcommands (design §13). Dispatch exits — they are top-level commands, not a launch
# path. The legacy --list/--stop/--remove/--clean flags keep their own dispatch below (back-compat).
if [ "$SUB_LIST" = true ]; then
    . "$HARNESSED_DIR/lib/harnessed-cli.sh"; list_all; exit 0
fi
if [ "$SUB_STOP" = true ]; then
    . "$HARNESSED_DIR/lib/harnessed-cli.sh"; stop_stack "$SUB_STOP_STACK"; exit 0
fi
if [ "$SUB_REMOVE" = true ]; then
    . "$HARNESSED_DIR/lib/harnessed-cli.sh"; rm_stack "$SUB_RM_STACK"; exit 0
fi
if [ "$SUB_NEW" = true ]; then
    . "$HARNESSED_DIR/lib/harnessed-cli.sh"; new_stack "$SUB_NEW_STACK" "$SUB_NEW_HARNESS" "$SUB_NEW_RECIPES"; exit 0
fi

# --- Image-only operations -------------------------------------------------
if [ "$BUILD" = true ]; then
    if [ -n "$BUILD_STACK" ]; then
        # `harnessed build <stack>` → emit-only assemble + host podman build (design §15, D-12).
        build_stack "$BUILD_STACK"
    else
        # bare `harnessed build` / `--build` → (re)build the base/claude/hatago images.
        build_images true
    fi
    exit 0
fi

# --- Capability test (design §18 / D-10, D-11) -----------------------------
# `harnessed test <stack>`: ensure the stack is built, then run the per-stack capability test —
# launch --fresh HEADLESS (the 02-02 launcher) + assert the manifest's declared capabilities are
# live. The test drives HOST podman (launch + `podman exec` introspection + teardown), so it runs
# host-native python — NOT the emit-only tools image (no daemon-in-container). The SAME structured
# result drives the markdown report AND the exit code; its non-zero status propagates (green/red).
if [ "$TEST" = true ]; then
    if [ -z "$TEST_STACK" ]; then
        print_error "harnessed test: stack name required (usage: harnessed test <stack>)"; usage; exit 1
    fi
    if [ ! -f "$HARNESSED_DIR/stacks/$TEST_STACK/stack.yaml" ]; then
        print_error "Unknown stack: $TEST_STACK (no stacks/$TEST_STACK/stack.yaml)"; usage; exit 1
    fi
    # Ensure built: assembled profile + hatago image. Assemble + build if either is missing.
    if [ ! -d "$HARNESSED_DIR/profiles/$TEST_STACK/.claude" ] || ! image_exists "$HARNESSED_HATAGO_IMAGE"; then
        print_info "Stack '$TEST_STACK' not fully built — assembling + building hatago first"
        build_stack "$TEST_STACK"
    fi
    # Ensure the harness/base images exist (the pod's harness member runs the capability probes).
    ensure_images
    # The host-side test needs ruamel.yaml + rich. Resolution order (keeps the persistent host
    # dependency surface at "podman only"):
    #   1. HARNESSED_PYTHON override — an interpreter the operator guarantees has the deps.
    #   2. uv (ephemeral --with deps; no host-python pollution) — preferred.
    #   3. a host python3 that already imports ruamel.yaml + rich.
    # set -e would abort on a red result; capture the status and propagate it as the exit code.
    test_rc=0
    run_env=(PYTHONPATH="$HARNESSED_DIR/tools" CONTAINER_RUNTIME="$CONTAINER_RUNTIME" HARNESSED_DIR="$HARNESSED_DIR")
    if [ -n "${HARNESSED_PYTHON:-}" ]; then
        env "${run_env[@]}" "$HARNESSED_PYTHON" -m harnessed.cli test "${TEST_ARGS[@]}" --root "$HARNESSED_DIR" || test_rc=$?
    elif command -v uv >/dev/null 2>&1; then
        env "${run_env[@]}" uv run --no-project --quiet --with ruamel.yaml --with rich \
            python -m harnessed.cli test "${TEST_ARGS[@]}" --root "$HARNESSED_DIR" || test_rc=$?
    elif command -v python3 >/dev/null 2>&1 && python3 -c 'import ruamel.yaml, rich' >/dev/null 2>&1; then
        env "${run_env[@]}" python3 -m harnessed.cli test "${TEST_ARGS[@]}" --root "$HARNESSED_DIR" || test_rc=$?
    else
        print_error "harnessed test needs 'uv' (recommended) or a host python3 with ruamel.yaml + rich."
        print_error "Install uv (https://astral.sh/uv) or run: pip install ruamel.yaml rich (or set HARNESSED_PYTHON)."
        exit 1
    fi
    exit "$test_rc"
fi
if [ "$LIST" = true ]; then list_instances; exit 0; fi
if [ "$CLEAN" = true ]; then clean_instances; exit 0; fi

# --- Resolve project path → instance ---------------------------------------
[ -z "$PROJECT_PATH" ] && PROJECT_PATH="$(pwd)"
PROJECT_PATH="$(cd "$PROJECT_PATH" 2>/dev/null && pwd || echo "$PROJECT_PATH")"
INSTANCE="$(generate_instance_name "$STACK" "$PROJECT_PATH")"

if [ "$STOP" = true ]; then stop_instance "$INSTANCE"; exit 0; fi
if [ "$REMOVE" = true ]; then remove_instance "$INSTANCE"; exit 0; fi

# --- Launch the stack ------------------------------------------------------
ensure_images

case "$STACK" in
    transparent)
        # shellcheck source=lib/harnessed-transparent.sh
        . "$HARNESSED_DIR/lib/harnessed-transparent.sh"
        harnessed_transparent "$PROJECT_PATH" "$CLAUDE" "$ZAI"
        ;;
    *)
        # Isolated stacks: any non-transparent stack, resolved against stacks/<stack>/stack.yaml.
        if [ ! -f "$HARNESSED_DIR/stacks/$STACK/stack.yaml" ]; then
            print_error "Unknown stack: $STACK (no stacks/$STACK/stack.yaml)"
            usage
            exit 1
        fi
        # shellcheck source=lib/harnessed-isolated.sh
        . "$HARNESSED_DIR/lib/harnessed-isolated.sh"
        harnessed_isolated "$STACK" "$PROJECT_PATH" "$FRESH"
        ;;
esac
