# harnessed — host-level secrets, resolved from 1Password via varlock.
#
# Copy to ~/.config/harnessed/.env.schema and edit the op:// references.
# Per-service secrets live in ~/.config/<service>/.env.schema
#   (e.g. ~/.config/hindsight/.env.schema for the hindsight sidecar).
# `harnessed` detects these schemas and injects resolved env via `varlock run --`
# at launch; values are NEVER written to the repo, a profile, or an image layer.
#
# DSL reference: https://varlock.dev/env-spec
#
# @plugin(@varlock/1password-plugin@1.2.0)
# @initOp(allowAppAuth=true)
# ---

# --- Supply-chain scanners (see docs/harnessed-design.md §7) ---
# All optional. If unset, harnessed runs only the credential-free scanners
# (osv-scanner + pip-audit) as the baseline `harnessed build` gate.

# Snyk API token — used by `snyk test` during `harnessed build`.
# @optional @sensitive @example="abcd1234-ef56-7890-..."
SNYK_TOKEN=op(op://Private/SNYK_API_TOKEN/credential)

# Socket.dev API key — optional, deeper supply-chain signals.
# @optional @sensitive @example="sktsec_..."
SOCKET_SECURITY_API_KEY=op(op://Private/SocketDev/credential)
