#!/usr/bin/env bash
# harnessed in-image supply-chain scan (BLD-02). Baked into harnessed-base; invoked as the final RUN
# layer of every assembled stack image (emit.write_derived_dockerfile). Scans what the build actually
# installed — mise-managed node globals and recipe installs under ~/.claude — because those vendor no
# top-level lockfile a host-side scan could see.
#
# ADVISORY, never gating. harnessed installs third-party agent tooling by running upstream installers,
# whose JS dependency trees almost always carry open HIGHs at any moment — a hard build-gate on those
# would make the recipe system unusable. So the scan REPORTS posture and always exits 0. Each scanner
# runs in JSON mode; a single compact severity summary is printed (raw JSON only with
# HARNESSED_SCAN_VERBOSE=1) and a consolidated report is written to ~/.harnessed/scan-report.json,
# which the launcher copies into the stack profile dir. snyk is token-gated via a build SECRET
# (--mount=type=secret,id=snyk_token); without a token snyk is skipped and only the credential-free
# osv-scanner / pip-audit contribute.
set -uo pipefail

HOME_DIR="${HOME:-/home/harnessed}"
REPORT_DIR="$HOME_DIR/.harnessed"
REPORT="$REPORT_DIR/scan-report.json"
WORK="$(mktemp -d)"
MANIFEST="$WORK/manifest"
: >"$MANIFEST"
mkdir -p "$REPORT_DIR"

# SNYK_TOKEN arrives as a build secret (never a build-arg → never baked into image history).
if [[ -r /run/secrets/snyk_token ]]; then
    SNYK_TOKEN="$(cat /run/secrets/snyk_token)"
    export SNYK_TOKEN
fi

# snyk-scan a node_modules tree that has no top-level manifest: synthesize a package.json from the
# on-disk packages, symlink the real node_modules, capture JSON, and record it in $MANIFEST.
snyk_scan() {
    local nm="$1" label="$2" tmp out
    [[ -d "$nm" ]] || return 0
    command -v snyk >/dev/null 2>&1 || return 0
    [[ -n "${SNYK_TOKEN:-}" ]] || return 0
    echo "  · snyk: ${label}"
    tmp="$(mktemp -d)" || return 0
    ln -s "$nm" "$tmp/node_modules"
    python3 - "$nm" >"$tmp/package.json" <<'PY'
import sys, os, json
nm = sys.argv[1]
deps = {}
def add(d):
    try:
        with open(os.path.join(d, "package.json")) as f:
            p = json.load(f)
        deps[p["name"]] = p.get("version", "*")
    except Exception:
        pass
for entry in sorted(os.listdir(nm)):
    path = os.path.join(nm, entry)
    if not os.path.isdir(path):
        continue
    if entry.startswith("@"):                 # scoped packages live one level down
        for sub in sorted(os.listdir(path)):
            add(os.path.join(path, sub))
    else:
        add(path)
json.dump({"name": "harnessed-globals-audit", "version": "0.0.0", "dependencies": deps}, sys.stdout)
PY
    out="$WORK/snyk-$(printf '%s' "$label" | tr -c 'A-Za-z0-9' '_').json"
    ( cd "$tmp" && snyk test --json ) >"$out" 2>/dev/null
    rm -rf "$tmp"
    [[ -s "$out" ]] && printf 'snyk|%s|%s\n' "$label" "$out" >>"$MANIFEST"
}

echo "== harnessed supply-chain scan (advisory) =="

# 1. mise-installed node globals (node-release-bundled npm/corepack), deduped via realpath.
declare -A seen=()
for nm in "$HOME_DIR"/.local/share/mise/installs/node/*/lib/node_modules; do
    [[ -d "$nm" ]] || continue
    real="$(realpath "$nm")"
    [[ -n "${seen[$real]:-}" ]] && continue
    seen[$real]=1
    snyk_scan "$real" "node globals"
done
unset seen

# 2. recipe-installed node trees under the Claude-canonical profile.
for nm in "$HOME_DIR"/.claude/skills/*/node_modules "$HOME_DIR"/.claude/commands/*/node_modules; do
    [[ -d "$nm" ]] || continue
    snyk_scan "$(realpath "$nm")" "recipe: $(basename "$(dirname "$nm")")"
done

# 3. osv-scanner over recipe trees that ship a real lockfile (sees bun.lock/package-lock that snyk's
#    synth manifest misses). One JSON pass over the whole profile.
if command -v osv-scanner >/dev/null 2>&1; then
    osv_dirs=()
    [[ -d "$HOME_DIR/.claude/skills" ]] && osv_dirs+=("$HOME_DIR/.claude/skills")
    [[ -d "$HOME_DIR/.claude/commands" ]] && osv_dirs+=("$HOME_DIR/.claude/commands")
    if [[ ${#osv_dirs[@]} -gt 0 ]]; then
        echo "  · osv-scanner: recipe lockfiles"
        osv-scanner scan source --recursive --format json "${osv_dirs[@]}" >"$WORK/osv.json" 2>/dev/null
        [[ -s "$WORK/osv.json" ]] && printf 'osv|recipe lockfiles|%s\n' "$WORK/osv.json" >>"$MANIFEST"
    fi
fi

# 4. pip-audit over the active Python env.
if command -v pip-audit >/dev/null 2>&1; then
    echo "  · pip-audit: python env"
    pip-audit --format=json >"$WORK/pip-audit.json" 2>/dev/null
    [[ -s "$WORK/pip-audit.json" ]] && printf 'pip-audit|python env|%s\n' "$WORK/pip-audit.json" >>"$MANIFEST"
fi

# Summarize every scanner's JSON into one compact table + a consolidated report. Advisory only.
HARNESSED_SCAN_REPORT="$REPORT" python3 - "$MANIFEST" <<'PY'
import sys, os, json

rows = []   # {source, tool, critical, high, other, notable:[...]}

def sev_from_cvss(score):
    try:
        s = float(score)
    except (TypeError, ValueError):
        return None
    if s >= 9.0: return "critical"
    if s >= 7.0: return "high"
    if s >= 4.0: return "medium"
    if s > 0:    return "low"
    return None

def load(path):
    try:
        with open(path) as f:
            return json.load(f)
    except Exception:
        return None

def parse_snyk(doc):
    # snyk --json is one object, or a list when multiple projects are detected. Dedup by vuln id.
    projects = doc if isinstance(doc, list) else [doc]
    by_id = {}
    for proj in projects:
        for v in (proj or {}).get("vulnerabilities", []) or []:
            vid = v.get("id")
            if vid:
                by_id[vid] = ((v.get("severity") or "").lower(), v.get("packageName") or v.get("name") or "?")
    return list(by_id.values())

def parse_osv(doc):
    # osv-scanner --format json: results[].packages[].groups[].max_severity is a CVSS score string.
    items = []
    for res in (doc or {}).get("results", []) or []:
        for pkg in res.get("packages", []) or []:
            name = (pkg.get("package") or {}).get("name", "?")
            for grp in pkg.get("groups", []) or []:
                sev = sev_from_cvss(grp.get("max_severity"))
                if sev:
                    items.append((sev, name))
    return items

def parse_pip_audit(doc):
    # pip-audit --format=json: {"dependencies":[{"name","vulns":[...]}]} (no severity field).
    items = []
    deps = doc.get("dependencies", []) if isinstance(doc, dict) else (doc or [])
    for dep in deps:
        for _v in dep.get("vulns", []) or []:
            items.append(("unknown", dep.get("name", "?")))
    return items

PARSERS = {"snyk": parse_snyk, "osv": parse_osv, "pip-audit": parse_pip_audit}

with open(sys.argv[1]) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        tool, source, path = line.split("|", 2)
        doc = load(path)
        if doc is None:
            continue
        items = PARSERS[tool](doc)
        crit = sum(1 for s, _ in items if s == "critical")
        high = sum(1 for s, _ in items if s == "high")
        notable, seen = [], set()
        for want in ("critical", "high"):
            for s, pkg in items:
                if s == want and pkg not in seen:
                    seen.add(pkg); notable.append(pkg)
        rows.append({"source": source, "tool": tool, "critical": crit,
                     "high": high, "other": len(items) - crit - high, "notable": notable[:4]})

tot_c = sum(r["critical"] for r in rows)
tot_h = sum(r["high"] for r in rows)

report = {"advisory": True, "gating": 0,
          "totals": {"critical": tot_c, "high": tot_h},
          "sources": rows}
try:
    with open(os.environ["HARNESSED_SCAN_REPORT"], "w") as f:
        json.dump(report, f, indent=2)
except Exception:
    pass

flagged = [r for r in rows if r["critical"] or r["high"]]
print("")
print("  supply-chain summary — advisory (build not gated)")
if not rows:
    print("  (no scanner output — snyk token absent and/or scanners missing)")
elif not flagged:
    print("  no high/critical advisories across %d source(s)." % len(rows))
else:
    print("  %-34s %4s %4s   notable packages" % ("SOURCE", "CRIT", "HIGH"))
    for r in sorted(flagged, key=lambda r: (-r["critical"], -r["high"])):
        label = ("%s · %s" % (r["tool"], r["source"]))[:34]
        print("  %-34s %4d %4d   %s" % (label, r["critical"], r["high"], ", ".join(r["notable"])))
    print("  " + "-" * 62)
print("  %d critical · %d high across %d source(s) · 0 gating" % (tot_c, tot_h, len(rows)))
print("  full report: %s" % os.environ.get("HARNESSED_SCAN_REPORT", "?"))
print("")
PY

# Escape hatch: dump raw scanner JSON for debugging (suppressed by default to keep builds readable).
if [[ -n "${HARNESSED_SCAN_VERBOSE:-}" ]]; then
    echo "-- HARNESSED_SCAN_VERBOSE: raw scanner JSON --"
    for f in "$WORK"/*.json; do
        [[ -e "$f" ]] || continue
        echo "### $f"; cat "$f"
    done
fi

rm -rf "$WORK"
exit 0
